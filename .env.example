# HTTP
FAUCET_IMAGE=ghcr.io/retricsu/cwbtc-faucet:latest
PORT=3008
FAUCET_PORT=3008
HOST=0.0.0.0
PUBLIC_BASE_URL=http://localhost:3008
CORS_ORIGIN=http://localhost:3008
TRUST_PROXY_HOPS=1

# CKB testnet
CKB_RPC_URL=https://testnet.ckbapp.dev/

# Created automatically by ./scripts/init.sh. Do not use the issuer key.
FAUCET_PRIVATE_KEY_SECRET_FILE=./secrets/faucet_private_key
IP_HASH_SALT_SECRET_FILE=./secrets/ip_hash_salt
ADMIN_TOKEN_SECRET_FILE=./secrets/admin_token
TURNSTILE_SECRET_KEY_SECRET_FILE=./secrets/turnstile_secret_key

# cWBTC claim amount is raw units. 10000000000 = 100 cWBTC because cWBTC has 8 decimals.
CLAIM_AMOUNT_RAW=10000000000
ADDRESS_COOLDOWN_SECONDS=86400
IP_COOLDOWN_SECONDS=3600
ADDRESS_DAILY_CLAIM_LIMIT=1
IP_DAILY_CLAIM_LIMIT=5
GLOBAL_DAILY_CLAIM_LIMIT=200

# SQLite state
DATABASE_PATH=./data/faucet.sqlite

# Worker behavior
WORKER_ENABLED=true
WORKER_POLL_MS=3000
TX_CONFIRM_TIMEOUT_MS=180000
TX_CONFIRM_POLL_MS=3000

# Optional Cloudflare Turnstile. If REQUIRE_TURNSTILE=false, the faucet still runs without it.
REQUIRE_TURNSTILE=false
TURNSTILE_SITE_KEY=
